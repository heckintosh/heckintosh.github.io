---
import Card from "./Card/index.astro";
import { LINKS } from "@/lib/constants";
import { Icon } from 'astro-icon/components';
import Tooltip from "./Tooltip/index";
import AsciiArtCanvas from "./AsciiArtCanvas";
---

<Card colSpan="md:col-span-3" rowSpan="md:row-span-4">
  <div class="flex w-full h-full min-h-[14rem] relative">
    <!-- Text content -->
    <div class="flex flex-col justify-between gap-4 relative z-10">
      <div class="flex flex-col gap-2">
        <span class="text-xs text-primary/60 font-mono tracking-widest uppercase">welcome</span>
        <h1 class="m-0 font-bold text-2xl leading-tight text-foreground">
          Hi, I'm <span class="text-primary">Anh</span>.
        </h1>
        <p class="m-0 text-sm text-muted-foreground leading-relaxed max-w-[280px]">
          Security enthusiast who loves to break stuff.<br />
          I share things here.
        </p>
      </div>

      <div class="flex gap-2 flex-wrap">
        <a href={LINKS.github} aria-label="GitHub profile" target="_blank"
          class="flex items-center gap-1.5 px-3 py-1.5 text-xs border border-border rounded font-mono text-muted-foreground hover:text-primary hover:border-primary/40 transition-colors duration-150">
          <Icon name="ri:github-fill" class="h-3.5 w-3.5" />
          github
        </a>
        <a href={LINKS.linkedin} aria-label="LinkedIn profile" target="_blank"
          class="flex items-center gap-1.5 px-3 py-1.5 text-xs border border-border rounded font-mono text-muted-foreground hover:text-primary hover:border-primary/40 transition-colors duration-150">
          <Icon name="ri:linkedin-box-fill" class="h-3.5 w-3.5" />
          linkedin
        </a>
        <a href={LINKS.x} aria-label="X / Twitter" target="_blank"
          class="flex items-center gap-1.5 px-3 py-1.5 text-xs border border-border rounded font-mono text-muted-foreground hover:text-primary hover:border-primary/40 transition-colors duration-150">
          <Icon name="ri:twitter-x-fill" class="h-3.5 w-3.5" />
          twitter
        </a>
        <Tooltip client:visible>
          <button class="flex items-center gap-1.5 px-3 py-1.5 text-xs border border-border rounded font-mono text-muted-foreground hover:text-primary hover:border-primary/40 transition-colors duration-150" aria-label="Easter egg">
            <Icon name="ri:terminal-box-fill" class="h-3.5 w-3.5" />
            <span class="sr-only">Easter egg</span>
            <span aria-hidden>~</span>
          </button>
        </Tooltip>
      </div>
    </div>

    <!-- ASCII particle art, positioned as bg decoration -->
    <AsciiArtCanvas client:load />
  </div>
</Card>

<style>
  /*
   * :global() is required here because the <pre> is rendered by React —
   * Astro's scoped-CSS hash is NOT added to React component output,
   * so a plain .ascii-art rule would never match.
   */
  :global(.ascii-art) {
    position: absolute;
    z-index: 0;
    pointer-events: none;
    margin: 0;
    padding: 0;
    white-space: pre;
    font-family: 'JetBrains Mono', monospace;
    line-height: 1.2;
    color: #facc15;
    overflow: hidden;

    /* Spotlight: 100% visible at cursor, 30% visible elsewhere */
    -webkit-mask-image: radial-gradient(
      ellipse 55% 55% at var(--mx, 70%) var(--my, 50%),
      rgba(0,0,0,1)   0%,
      rgba(0,0,0,0.3) 100%
    );
    mask-image: radial-gradient(
      ellipse 55% 55% at var(--mx, 70%) var(--my, 50%),
      rgba(0,0,0,1)   0%,
      rgba(0,0,0,0.3) 100%
    );

    /* Mobile: scaled down, anchored bottom-right */
    font-size: 6px;
    right: -10px;
    bottom: -10px;
    top: auto;
    max-width: 70%;
    max-height: calc(100% + 20px);
    transform-origin: bottom right;
  }

  @media (min-width: 768px) {
    :global(.ascii-art) {
      font-size: 7px;
      right: -15px;
      top: 50%;
      bottom: auto;
      max-width: 60%;
      max-height: none;
      transform: translateY(-50%);
      transform-origin: center right;
    }
  }

  @media (min-width: 1024px) {
    :global(.ascii-art) {
      font-size: 8px;
      right: -20px;
    }
  }

  @media (min-width: 1280px) {
    :global(.ascii-art) {
      font-size: 9px;
      right: -25px;
    }
  }
</style>

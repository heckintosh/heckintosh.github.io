---
import Card from "./Card/index.astro";
import { LINKS } from "@/lib/constants";
import { Icon } from 'astro-icon/components';
---

<Card colSpan="md:col-span-3" rowSpan="md:row-span-4">
  <div class="flex w-full h-full min-h-[14rem] relative">
    <!-- Text content -->
    <div class="flex flex-col justify-between gap-4 relative z-10">
      <div class="flex flex-col gap-2">
        <span class="text-xs text-primary/60 font-mono tracking-widest uppercase">welcome // heckintosh</span>
        <h1 id="intro-title" class="m-0 font-bold text-2xl leading-tight text-foreground cursor-pointer select-none">
          Hi, I'm <span class="text-primary">Anh</span>.
        </h1>
        <p id="intro-desc" class="m-0 text-sm text-muted-foreground leading-relaxed max-w-[280px] cursor-pointer select-none">
          breaking things,<br />responsibly.
        </p>
      </div>

      <div class="flex gap-2 flex-wrap">
        <a href={LINKS.github} aria-label="GitHub profile" target="_blank"
          class="flex items-center gap-1.5 px-3 py-1.5 text-xs border border-border rounded font-mono text-muted-foreground hover:text-primary hover:border-primary/40 transition-colors duration-150">
          <Icon name="ri:github-fill" class="h-3.5 w-3.5" />
          github
        </a>
        <a href={LINKS.linkedin} aria-label="LinkedIn profile" target="_blank"
          class="flex items-center gap-1.5 px-3 py-1.5 text-xs border border-border rounded font-mono text-muted-foreground hover:text-primary hover:border-primary/40 transition-colors duration-150">
          <Icon name="ri:linkedin-box-fill" class="h-3.5 w-3.5" />
          linkedin
        </a>
        <a href={LINKS.x} aria-label="X / Twitter" target="_blank"
          class="flex items-center gap-1.5 px-3 py-1.5 text-xs border border-border rounded font-mono text-muted-foreground hover:text-primary hover:border-primary/40 transition-colors duration-150">
          <Icon name="ri:twitter-x-fill" class="h-3.5 w-3.5" />
          twitter
        </a>
        <button class="flex items-center gap-1.5 px-3 py-1.5 text-xs border border-border rounded font-mono text-muted-foreground hover:text-primary hover:border-primary/40 transition-colors duration-150" aria-label="Easter egg" title="~">
          <Icon name="ri:terminal-box-fill" class="h-3.5 w-3.5" />
          <span class="sr-only">Easter egg</span>
          <span aria-hidden>~</span>
        </button>
      </div>
    </div>

    <!-- ASCII particle art, positioned as bg decoration -->
    <div class="ascii-art">
      <canvas id="ascii-canvas" class="ascii-canvas"></canvas>
    </div>
  </div>
</Card>

<script>
  const CHARS = "!<>-_\\/[]{}—=+*^?#|@$%&";
  const FULL  = "Hi, I'm Anh.";

  function scramble(el: HTMLElement) {
    let frame = 0;
    const totalFrames = 22;
    let rafId = 0;

    function tick() {
      frame++;
      const revealedCount = Math.floor((frame / totalFrames) * FULL.length);
      let out = "";
      for (let i = 0; i < FULL.length; i++) {
        if (FULL[i] === " " || FULL[i] === "'") {
          out += FULL[i];
        } else if (i < revealedCount) {
          out += FULL[i];
        } else {
          out += CHARS[Math.floor(Math.random() * CHARS.length)];
        }
      }
      el.textContent = out;
      if (frame < totalFrames) {
        rafId = requestAnimationFrame(tick);
      } else {
        // Restore HTML with the coloured span
        el.innerHTML = "Hi, I'm <span class=\"text-primary\">Anh</span>.";
      }
    }

    cancelAnimationFrame(rafId);
    frame = 0;
    rafId = requestAnimationFrame(tick);
  }

  const DESC = "breaking things,\nresponsibly.";

  function scrambleFlat(el: HTMLElement, original: string) {
    let frame = 0;
    const totalFrames = 28;
    let rafId = 0;

    function tick() {
      frame++;
      const revealedCount = Math.floor((frame / totalFrames) * original.length);
      let out = "";
      for (let i = 0; i < original.length; i++) {
        if (original[i] === " " || original[i] === "\n" || original[i] === ".") {
          out += original[i];
        } else if (i < revealedCount) {
          out += original[i];
        } else {
          out += CHARS[Math.floor(Math.random() * CHARS.length)];
        }
      }
      // Convert newline back to <br>
      el.innerHTML = out.replace("\n", "<br />");
      if (frame < totalFrames) {
        rafId = requestAnimationFrame(tick);
      }
    }

    cancelAnimationFrame(rafId);
    frame = 0;
    rafId = requestAnimationFrame(tick);
  }

  const title = document.getElementById("intro-title");
  if (title) {
    title.addEventListener("mouseenter", () => scramble(title));
    title.addEventListener("click",      () => scramble(title));
  }

  const desc = document.getElementById("intro-desc");
  if (desc) {
    desc.addEventListener("mouseenter", () => scrambleFlat(desc, DESC));
    desc.addEventListener("click",      () => scrambleFlat(desc, DESC));
  }

  function initAscii() {
    const canvas = document.getElementById("ascii-canvas") as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    const FONT_SIZE = 9;
    const LINE_H = FONT_SIZE * 1.2;
    const FONT = `${FONT_SIZE}px 'JetBrains Mono', monospace`;
    const SPRING = 0.1;
    const DAMP = 0.72;
    const REPEL_R = 55;
    const REPEL_F = 5.5;
    const FRAME_MS = 40;

    const charColor = (disp: number) => {
      const t = Math.min(disp / 24, 1);
      const r = Math.round(136 + t * 104);
      const g = Math.round(146 + t * 62);
      const b = Math.round(160 - t * 80);
      return `rgb(${r},${g},${b})`;
    };

    const curated = [2, 3, 4, 6, 7, 9];
    const n = curated[Math.floor(Math.random() * curated.length)];
    fetch(`/ascii-art-${n}.txt`)
      .then(r => r.text())
      .then(text => {
        const mc = document.createElement("canvas").getContext("2d");
        if (!mc) return;
        mc.font = FONT;
        const charW = mc.measureText("M").width;

        const lines = text.split("\n");
        const particles: Array<{ ch: string; hx: number; hy: number; x: number; y: number; vx: number; vy: number; }> = [];
        let canvasW = 0;
        let canvasH = 0;

        lines.forEach((line, row) => {
          const hy = row * LINE_H + FONT_SIZE;
          [...line].forEach((ch, col) => {
            if (ch === " ") return;
            const hx = col * charW;
            particles.push({ ch, hx, hy, x: hx, y: hy, vx: 0, vy: 0 });
            if (hx + charW > canvasW) canvasW = hx + charW;
          });
          if (hy > canvasH) canvasH = hy;
        });
        canvasH += FONT_SIZE;

        const dpr = window.devicePixelRatio || 1;
        canvas.width = Math.ceil(canvasW * dpr);
        canvas.height = Math.ceil(canvasH * dpr);
        canvas.style.width = `${canvasW}px`;
        canvas.style.height = `${canvasH}px`;
        ctx.scale(dpr, dpr);
        ctx.imageSmoothingEnabled = true;
        ctx.font = FONT;

        const baseCanvas = document.createElement("canvas");
        baseCanvas.width = canvas.width;
        baseCanvas.height = canvas.height;
        const bctx = baseCanvas.getContext("2d");
        if (!bctx) return;
        bctx.scale(dpr, dpr);
        bctx.font = FONT;
        bctx.fillStyle = charColor(0);
        for (const p of particles) bctx.fillText(p.ch, p.hx, p.hy);

        let mx = -9999;
        let my = -9999;
        let running = false;
        let rafId = 0;
        let lastTs = 0;

        const stopLoop = () => {
          running = false;
          cancelAnimationFrame(rafId);
        };

        const frame = (ts: number) => {
          if (!running) return;
          if (ts - lastTs < FRAME_MS) {
            rafId = requestAnimationFrame(frame);
            return;
          }
          lastTs = ts;

          const pointerActive = mx > -9000 && my > -9000;
          ctx.clearRect(0, 0, canvasW, canvasH);
          // Important: don't paint the static base while hovering, or it looks like
          // a "ghost/original ascii" is sitting underneath the transformed one.
          if (!pointerActive) {
            ctx.drawImage(baseCanvas, 0, 0, canvasW, canvasH);
          }
          const cx = canvasW * 0.5;
          const cy = canvasH * 0.5;
          const px = (mx - cx) / Math.max(canvasW, 1);
          const py = (my - cy) / Math.max(canvasH, 1);
          let anyMoving = false;

          for (const p of particles) {
            const dx = p.x - mx;
            const dy = p.y - my;
            const distSq = dx * dx + dy * dy;
            const nearHome =
              Math.abs(p.x - p.hx) < 0.08 &&
              Math.abs(p.y - p.hy) < 0.08 &&
              Math.abs(p.vx) < 0.02 &&
              Math.abs(p.vy) < 0.02;

            if (!pointerActive && nearHome) continue;

            if (pointerActive && distSq < REPEL_R * REPEL_R && distSq > 0.25) {
              const dist = Math.sqrt(distSq);
              const strength = ((REPEL_R - dist) / REPEL_R) ** 2 * REPEL_F;
              p.vx += (dx / dist) * strength;
              p.vy += (dy / dist) * strength;
            }

            if (pointerActive) {
              const wave = Math.sin(p.hx * 0.04 + p.hy * 0.03 + ts * 0.008);
              const wave2 = Math.cos(p.hx * 0.03 + p.hy * 0.05 + ts * 0.007);
              // Global field transform so the whole ASCII mass reacts on hover.
              p.vx += px * 0.28 + wave * 0.06;
              p.vy += py * 0.28 + wave2 * 0.06;
            }

            p.vx += (p.hx - p.x) * SPRING;
            p.vy += (p.hy - p.y) * SPRING;
            p.vx *= DAMP;
            p.vy *= DAMP;
            p.x += p.vx;
            p.y += p.vy;
            anyMoving = true;

            const disp = Math.sqrt((p.x - p.hx) ** 2 + (p.y - p.hy) ** 2);
            ctx.fillStyle = charColor(disp);
            ctx.fillText(p.ch, p.x, p.y);
          }

          if (!pointerActive && !anyMoving) {
            stopLoop();
            return;
          }

          rafId = requestAnimationFrame(frame);
        };

        const startLoop = () => {
          if (running) return;
          running = true;
          rafId = requestAnimationFrame(frame);
        };

        const onMove = (e: PointerEvent) => {
          const rect = canvas.getBoundingClientRect();
          mx = e.clientX - rect.left;
          my = e.clientY - rect.top;
          startLoop();
        };
        const onLeave = () => {
          mx = -9999;
          my = -9999;
        };

        ctx.drawImage(baseCanvas, 0, 0, canvasW, canvasH);
        canvas.addEventListener("pointermove", onMove, { passive: true });
        canvas.addEventListener("pointerleave", onLeave, { passive: true });
      })
      .catch(() => {});
  }

  if ("requestIdleCallback" in window) {
    (window as any).requestIdleCallback(initAscii, { timeout: 1200 });
  } else {
    setTimeout(initAscii, 600);
  }
</script>

<style>
  /*
   * :global() is required here because the <pre> is rendered by React —
   * Astro's scoped-CSS hash is NOT added to React component output,
   * so a plain .ascii-art rule would never match.
   */
  :global(.ascii-art) {
    position: absolute;
    z-index: 0;
    pointer-events: auto;
    overflow: hidden;
    opacity: 0.88;
    filter: saturate(0.9) contrast(0.98);

    /* Mobile: scaled down, anchored bottom-right */
    right: -10px;
    bottom: -10px;
    top: auto;
    max-width: 84%;
    max-height: calc(100% + 20px);
    transform-origin: bottom right;
  }

  :global(.ascii-canvas) {
    display: block;
  }

  @media (min-width: 768px) {
    :global(.ascii-art) {
      right: -15px;
      top: 50%;
      bottom: auto;
      max-width: 76%;
      max-height: none;
      transform: translateY(-50%);
      transform-origin: center right;
    }
  }

  @media (min-width: 1024px) {
    :global(.ascii-art) {
      right: -20px;
    }
  }

  @media (min-width: 1280px) {
    :global(.ascii-art) {
      right: -25px;
    }
  }
</style>

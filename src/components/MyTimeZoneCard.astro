---
import Card from "./Card/index.astro";
import { getCurrentTimeInVietnam, formatTimeForVietnam } from "@/lib/helpers";
---

<Card colSpan="lg:col-span-1" rowSpan="md:row-span-2" title="my time">
  <div class="flex flex-col gap-1 flex-1">
    <time
      id="myTimeDisplay"
      class="text-3xl font-mono font-light tabular-nums text-foreground"
      datetime=""
    >
      {formatTimeForVietnam(getCurrentTimeInVietnam())}
    </time>
    <p class="text-xs text-muted-foreground font-mono m-0">Asia/Ho_Chi_Minh</p>
  </div>
</Card>

<script>
  function updateMyTime() {
    const el = document.getElementById("myTimeDisplay");
    if (!el) return;
    const now = new Date();
    const opts: Intl.DateTimeFormatOptions = {
      hour: "numeric", minute: "2-digit", second: "2-digit",
      hour12: true, timeZone: "Asia/Ho_Chi_Minh",
    };
    const str = new Intl.DateTimeFormat("en-US", opts).format(now);
    const [time, period] = str.split(" ");
    const color = period === "AM" ? "#f59e0b" : "#60a5fa";
    el.innerHTML = `<span style="color:${color}">${time}</span><span style="color:#4a4a5a;font-size:0.6em;margin-left:0.25em">${period}</span>`;
    el.setAttribute("datetime", now.toISOString());
  }

  // astro:page-load fires on every navigation (including back/forward),
  // so the interval restarts each time this page is shown.
  document.addEventListener("astro:page-load", () => {
    updateMyTime();
    const iv = setInterval(updateMyTime, 1000);
    document.addEventListener("astro:before-swap", () => clearInterval(iv), { once: true });
  });
</script>

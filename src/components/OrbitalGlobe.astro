---
import RealisticGlobe from "./RealisticGlobe";

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<div class={`geo-globe ${compact ? "geo-globe--compact" : "geo-globe--full"}`}>
  <div class="geo-globe__stage">
    <RealisticGlobe compact={compact} client:idle />
  </div>
</div>

<style>
  .geo-globe {
    width: 100%;
    display: grid;
    place-items: center;
    position: relative;
  }

  .geo-globe__stage {
    width: 100%;
    display: grid;
    place-items: center;
  }

  .geo-globe :global(.realistic-globe-canvas) {
    display: block;
    width: min(100%, 960px);
    height: auto;
    max-width: 100%;
  }

  .geo-globe--compact .geo-globe__stage {
    width: auto;
    padding: 0.35rem;
    border-radius: 0.9rem;
    border: 1px solid rgba(187, 203, 225, 0.48);
    background: linear-gradient(180deg, rgba(248, 252, 255, 0.56), rgba(236, 243, 251, 0.34));
    box-shadow:
      0 10px 24px rgba(14, 30, 51, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.62);
  }

  .geo-globe--compact :global(.realistic-globe-canvas) {
    width: 148px;
    filter: drop-shadow(0 10px 18px rgba(10, 20, 35, 0.14));
  }

  :global(html.dark) .geo-globe--compact .geo-globe__stage {
    border-color: rgba(77, 103, 138, 0.55);
    background: linear-gradient(180deg, rgba(10, 18, 31, 0.64), rgba(8, 15, 26, 0.42));
    box-shadow:
      0 12px 30px rgba(1, 6, 14, 0.34),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }
</style>

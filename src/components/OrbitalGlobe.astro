---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<div class={`orbital-globe ${compact ? "orbital-globe--compact" : "orbital-globe--full"}`}>
  <svg viewBox="0 0 200 200" role="img" aria-label="Visited countries globe">
    <defs>
      <radialGradient id="ocean" cx="30%" cy="24%" r="78%">
        <stop offset="0%" stop-color="#7db3f2" />
        <stop offset="46%" stop-color="#2f6fb3" />
        <stop offset="100%" stop-color="#13273d" />
      </radialGradient>
      <linearGradient id="land" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#8ed5a4" />
        <stop offset="100%" stop-color="#4ea777" />
      </linearGradient>
      <radialGradient id="shine" cx="28%" cy="20%" r="60%">
        <stop offset="0%" stop-color="rgba(255,255,255,0.34)" />
        <stop offset="100%" stop-color="rgba(255,255,255,0)" />
      </radialGradient>
      <filter id="pinGlow" x="-100%" y="-100%" width="300%" height="300%">
        <feGaussianBlur stdDeviation="2.2" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
      <clipPath id="sphereClip">
        <circle cx="100" cy="100" r="73" />
      </clipPath>
    </defs>

    <circle class="sphere-shadow" cx="100" cy="100" r="76" />
    <circle class="sphere-base" cx="100" cy="100" r="73" fill="url(#ocean)" />

    <g clip-path="url(#sphereClip)">
      <g class="graticule">
        <ellipse cx="100" cy="100" rx="65" ry="20" />
        <ellipse cx="100" cy="100" rx="65" ry="36" />
        <ellipse cx="100" cy="100" rx="65" ry="52" />
        <path d="M34 100H166" />
      </g>

      <g class="lands globe-rotor">
        <path d="M48 84c8-16 25-26 46-24c8 1 13 4 17 8c4 4 2 10-3 14c-3 2-7 3-10 7c-3 4-4 10-8 14c-5 5-13 8-22 8c-17 0-28-8-30-20c-1-4 3-5 6-7c2-1 3-4 4-7z" fill="url(#land)" />
        <path d="M110 74c12-1 26 2 33 8c6 4 8 10 5 16c-2 4-6 5-9 8c-4 4-4 11-9 15c-6 6-16 10-27 10c-10 0-16-4-18-10c-2-5 3-6 6-8c3-2 4-7 5-12c1-6 4-15 14-19z" fill="url(#land)" />
        <path d="M122 127c7-4 16-4 23 0c6 3 10 8 9 13c-1 7-9 13-20 14c-11 1-21-4-24-11c-2-6 4-13 12-16z" fill="url(#land)" />
      </g>

      <path class="flight-arc" d="M126 88Q128 90 124 95" />
      <path class="flight-arc" d="M124 95Q130 108 133 123" />

      <circle class="pin pin-tw" cx="126" cy="88" r="2.7" />
      <circle class="pin pin-vn" cx="124" cy="95" r="2.9" />
      <circle class="pin pin-au" cx="133" cy="123" r="3.1" />
    </g>

    <circle class="sphere-shine" cx="100" cy="100" r="73" fill="url(#shine)" />
    <circle class="atmos" cx="100" cy="100" r="75" />

    <ellipse class="orbit orbit-a" cx="100" cy="100" rx="86" ry="34" />
    <ellipse class="orbit orbit-b" cx="100" cy="100" rx="86" ry="34" transform="rotate(-18 100 100)" />
  </svg>
</div>

<style>
  .orbital-globe {
    width: 100%;
    display: grid;
    place-items: center;
  }

  .orbital-globe svg {
    width: min(100%, 520px);
    height: auto;
    display: block;
  }

  .orbital-globe--compact svg {
    width: 118px;
  }

  .orbital-globe--full svg {
    width: min(100%, 620px);
  }

  .sphere-shadow {
    fill: rgba(10, 18, 32, 0.22);
    filter: blur(0.6px);
  }

  .sphere-base {
    stroke: rgba(255, 255, 255, 0.24);
    stroke-width: 1;
  }

  .graticule path,
  .graticule ellipse {
    fill: none;
    stroke: rgba(255, 255, 255, 0.16);
    stroke-width: 0.7;
  }

  .globe-rotor {
    transform-origin: 100px 100px;
    animation: globeDrift 34s linear infinite;
  }

  .flight-arc {
    fill: none;
    stroke: rgba(248, 214, 98, 0.75);
    stroke-width: 1;
    stroke-dasharray: 2 2;
  }

  .pin {
    fill: rgba(250, 216, 102, 0.98);
    filter: url(#pinGlow);
  }

  .sphere-shine {
    mix-blend-mode: screen;
    opacity: 0.72;
  }

  .atmos {
    fill: none;
    stroke: rgba(127, 184, 255, 0.34);
    stroke-width: 3;
  }

  .orbit {
    fill: none;
    stroke: rgba(255, 255, 255, 0.22);
    stroke-width: 1;
    stroke-dasharray: 4 4;
    transform-origin: 100px 100px;
  }

  .orbit-a { animation: orbitSpin 26s linear infinite; }
  .orbit-b { animation: orbitSpinReverse 32s linear infinite; }

  @keyframes globeDrift {
    0% { transform: translateX(0) rotate(0deg); }
    50% { transform: translateX(-6px) rotate(8deg); }
    100% { transform: translateX(0) rotate(0deg); }
  }

  @keyframes orbitSpin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  @keyframes orbitSpinReverse {
    0% { transform: rotate(-18deg); }
    100% { transform: rotate(-378deg); }
  }

  :global(html.dark) .sphere-shadow {
    fill: rgba(0, 0, 0, 0.4);
  }

  :global(html.dark) .sphere-base {
    stroke: rgba(255, 255, 255, 0.18);
  }

  :global(html.dark) .graticule path,
  :global(html.dark) .graticule ellipse {
    stroke: rgba(255, 255, 255, 0.2);
  }

  :global(html.dark) .atmos {
    stroke: rgba(111, 173, 255, 0.42);
  }

  :global(html.dark) .orbit {
    stroke: rgba(255, 255, 255, 0.28);
  }
</style>

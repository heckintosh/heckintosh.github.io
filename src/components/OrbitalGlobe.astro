---
import RealisticGlobe from "./RealisticGlobe";

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<div class={`geo-globe ${compact ? "geo-globe--compact" : "geo-globe--full"}`}>
  <RealisticGlobe compact={compact} client:idle />
</div>

<style>
  .geo-globe {
    width: 100%;
    display: grid;
    place-items: center;
  }

  .geo-globe :global(.realistic-globe-canvas) {
    display: block;
    width: min(100%, 640px);
    height: auto;
    max-width: 100%;
  }

  .geo-globe--compact :global(.realistic-globe-canvas) {
    width: 132px;
  }

  .geo-globe--full :global(.realistic-globe-canvas) {
    width: min(100%, 640px);
  }
</style>

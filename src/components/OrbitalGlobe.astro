---
import RealisticGlobe from "./RealisticGlobe";

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<div class={`geo-globe ${compact ? "geo-globe--compact" : "geo-globe--full"}`}>
  <div class="geo-globe__frame">
    <div class="geo-globe__noise" aria-hidden="true"></div>
    <RealisticGlobe compact={compact} client:idle />
  </div>
</div>

<style>
  .geo-globe {
    width: 100%;
    display: grid;
    place-items: center;
    position: relative;
    isolation: isolate;
  }

  .geo-globe__frame {
    position: relative;
    display: grid;
    place-items: center;
    width: min(100%, 720px);
    padding: clamp(0.8rem, 2.1vw, 1.3rem);
    border-radius: 1.5rem;
    overflow: hidden;
    border: 1px solid rgba(185, 205, 230, 0.88);
    background:
      radial-gradient(circle at 26% 20%, rgba(255, 222, 127, 0.32), transparent 34%),
      radial-gradient(circle at 76% 18%, rgba(114, 164, 225, 0.32), transparent 38%),
      linear-gradient(160deg, rgba(248, 252, 255, 0.92), rgba(232, 240, 250, 0.72));
    box-shadow:
      0 24px 54px rgba(22, 40, 67, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.7);
  }

  .geo-globe__frame::before {
    content: "";
    position: absolute;
    inset: 0.65rem;
    border-radius: 1.1rem;
    border: 1px solid rgba(255, 255, 255, 0.5);
    pointer-events: none;
  }

  .geo-globe__frame::after {
    content: "";
    position: absolute;
    inset: auto 12% 8%;
    height: 24%;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(13, 32, 58, 0.12), transparent 72%);
    filter: blur(18px);
    pointer-events: none;
  }

  .geo-globe__noise {
    position: absolute;
    inset: 0;
    opacity: 0.24;
    pointer-events: none;
    mix-blend-mode: soft-light;
    background-image:
      radial-gradient(rgba(0, 0, 0, 0.14) 0.5px, transparent 0.5px);
    background-size: 5px 5px;
  }

  .geo-globe :global(.realistic-globe-canvas) {
    display: block;
    width: min(100%, 720px);
    height: auto;
    max-width: 100%;
    position: relative;
    z-index: 1;
    filter: drop-shadow(0 16px 34px rgba(11, 21, 37, 0.16));
  }

  .geo-globe--compact .geo-globe__frame {
    width: auto;
    padding: 0.45rem;
    border-radius: 1rem;
    border-color: rgba(189, 205, 226, 0.54);
    background:
      radial-gradient(circle at 28% 18%, rgba(255, 220, 124, 0.18), transparent 38%),
      radial-gradient(circle at 76% 18%, rgba(114, 164, 225, 0.2), transparent 38%),
      linear-gradient(160deg, rgba(249, 252, 255, 0.82), rgba(236, 242, 250, 0.44));
    box-shadow:
      0 10px 26px rgba(16, 32, 54, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.56);
  }

  .geo-globe--compact .geo-globe__frame::before,
  .geo-globe--compact .geo-globe__frame::after {
    display: none;
  }

  .geo-globe--compact .geo-globe__noise {
    opacity: 0.16;
  }

  .geo-globe--compact :global(.realistic-globe-canvas) {
    width: 146px;
    filter: drop-shadow(0 9px 18px rgba(11, 21, 37, 0.12));
  }

  :global(html.dark) .geo-globe__frame {
    border-color: rgba(72, 101, 141, 0.72);
    background:
      radial-gradient(circle at 26% 20%, rgba(255, 203, 91, 0.16), transparent 34%),
      radial-gradient(circle at 76% 18%, rgba(102, 171, 255, 0.18), transparent 38%),
      linear-gradient(155deg, rgba(8, 16, 29, 0.92), rgba(11, 21, 38, 0.82));
    box-shadow:
      0 28px 60px rgba(1, 6, 14, 0.42),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  :global(html.dark) .geo-globe__frame::before {
    border-color: rgba(122, 158, 208, 0.22);
  }

  :global(html.dark) .geo-globe__frame::after {
    background: radial-gradient(circle, rgba(0, 0, 0, 0.38), transparent 72%);
  }

  :global(html.dark) .geo-globe__noise {
    opacity: 0.16;
  }
</style>

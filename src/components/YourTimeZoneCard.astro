---
import Card from "@/components/Card/index.astro";
import Pulse from "@/components/Pulse.astro";
---

<Card colSpan="lg:col-span-1" rowSpan="md:row-span-2" title="your time">
  <div class="flex flex-col gap-1 flex-1">
    <time
      id="yourTimeDisplay"
      class="text-3xl font-mono font-light tabular-nums text-foreground"
      datetime=""
    >
      --:--:-- --
    </time>
    <p id="yourTzDisplay" class="text-xs text-muted-foreground font-mono m-0">detecting...</p>
  </div>
</Card>

<script>
  function updateYourTime() {
    const el  = document.getElementById("yourTimeDisplay");
    const tz  = document.getElementById("yourTzDisplay");
    if (!el) return;
    const now = new Date();
    const opts: Intl.DateTimeFormatOptions = {
      hour: "numeric", minute: "2-digit", second: "2-digit", hour12: true,
    };
    const str = now.toLocaleTimeString(undefined, opts);
    const [time, period] = str.split(" ");
    const color = period === "AM" ? "#b45309" : "#1e293b";
    el.innerHTML = `<span style="color:${color}">${time}</span><span style="color:#94a3b8;font-size:0.6em;margin-left:0.25em">${period}</span>`;
    el.setAttribute("datetime", now.toISOString());
    if (tz) tz.textContent = Intl.DateTimeFormat().resolvedOptions().timeZone;
  }

  document.addEventListener("astro:page-load", () => {
    updateYourTime();
    const iv = setInterval(updateYourTime, 1000);
    document.addEventListener("astro:before-swap", () => clearInterval(iv), { once: true });
  });
</script>

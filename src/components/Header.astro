---
import Container from '@/components/Container.astro';
import { NAV_LINKS } from '@/consts';
import { Image } from 'astro:assets';
import logo from '../../public/static/heckintosh.svg';
---

<header
  class="sticky top-0 z-50 border-b border-border/50 bg-background/80 backdrop-blur-md"
>
  <Container>
    <div class="flex items-center justify-between h-14 gap-6">
      <a href="/" class="flex items-center gap-2 group" title="Home">
        <Image
          src={logo}
          alt="heckintosh"
          class="h-8 w-8 grayscale opacity-60 group-hover:opacity-100 group-hover:grayscale-0 transition-all duration-300"
        />
        <span class="text-sm font-mono text-muted-foreground group-hover:text-foreground transition-colors hidden sm:inline">
          heckintosh
        </span>
      </a>

      <nav class="hidden sm:flex items-center gap-6 text-xs font-mono">
        {NAV_LINKS.map(item => (
          <a
            href={item.href}
            class="text-muted-foreground hover:text-primary transition-colors duration-150 tracking-wider uppercase"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <details class="sm:hidden relative">
        <summary
          class="list-none inline-flex h-9 w-9 cursor-pointer items-center justify-center rounded-md border border-input bg-background text-muted-foreground hover:bg-secondary/50 hover:text-foreground transition-colors"
          aria-label="Toggle menu"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="4" x2="20" y1="12" y2="12"></line>
            <line x1="4" x2="20" y1="6" y2="6"></line>
            <line x1="4" x2="20" y1="18" y2="18"></line>
          </svg>
        </summary>
        <div class="absolute right-0 mt-2 min-w-[10rem] rounded-md border border-border bg-background p-1 shadow-lg">
          {NAV_LINKS.map(item => (
            <a
              href={item.href}
              class="block rounded px-3 py-2 text-sm capitalize text-foreground/90 hover:bg-secondary/50"
            >
              {item.label}
            </a>
          ))}
        </div>
      </details>
    </div>
  </Container>
</header>

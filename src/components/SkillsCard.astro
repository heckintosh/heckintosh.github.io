---
import Card from "./Card/index.astro";

const categories = [
  {
    tag: "web",
    items: ["sqli", "xss", "ssrf", "lfi", "ssti", "deserialization"],
  },
  {
    tag: "rev",
    items: ["elf", "pe", "arm", "ghidra", "angr", "z3"],
  },
  {
    tag: "pwn",
    items: ["rop", "heap", "fmt-str", "pwntools", "gdb"],
  },
  {
    tag: "crypto",
    items: ["rsa", "aes", "ecc", "hash", "sage"],
  },
  {
    tag: "misc",
    items: ["forensics", "osint", "steg", "pcap"],
  },
];
---

<Card colSpan="md:col-span-1" rowSpan="md:row-span-4 lg:row-span-4" title="skills">
  <div class="flex flex-col gap-3 flex-1 overflow-hidden">
    {categories.map(cat => (
      <div class="flex flex-col gap-1.5">
        <span class="text-[10px] font-mono text-primary/70 tracking-widest uppercase">{cat.tag}</span>
        <div class="flex flex-wrap gap-1">
          {cat.items.map(item => (
            <span class="text-[10px] font-mono px-1.5 py-0.5 rounded border border-border/60 text-muted-foreground/80 bg-border/20">
              {item}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</Card>

---
import Card from "@/components/Card/index.astro";
import { getCollection } from "astro:content";
import { formatDate } from "@/lib/helpers";

const writeups = (await getCollection("writeups"))?.sort(
  (a, b) => (b.data.pubDate ?? new Date()).getTime() - (a.data.pubDate ?? new Date()).getTime()
);
---

<Card colSpan="md:col-span-1" rowSpan="md:row-span-2" title="writeups" href="/writeups">
  <div class="flex flex-col gap-2 overflow-hidden">
    {writeups?.slice(0, 4).map(w => (
      <a
        href={`/writeups/${w.id}`}
        class="flex items-baseline justify-between gap-2 py-1 border-b border-border/60 last:border-0 hover:border-primary/30 transition-colors group"
      >
        <span class="text-xs text-foreground/70 font-mono group-hover:text-primary/80 truncate transition-colors">
          {w.data.title}
        </span>
        {w.data.pubDate && (
          <time
            class="text-[10px] text-muted-foreground shrink-0 tabular-nums"
            datetime={w.data.pubDate.toISOString()}
          >
            {formatDate(w.data.pubDate)}
          </time>
        )}
      </a>
    ))}
  </div>
</Card>

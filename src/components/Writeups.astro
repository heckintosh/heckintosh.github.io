---
import Card from "@/components/Card/index.astro";
import { getCollection } from "astro:content";
import { formatDate } from "@/lib/helpers";

const writeups = (await getCollection("writeups"))?.sort(
  (a, b) => (b.data.pubDate ?? new Date()).getTime() - (a.data.pubDate ?? new Date()).getTime()
);
---

<Card colSpan="md:col-span-1" rowSpan="md:row-span-4" title="writeups" titleHref="/writeups">
  <div class="flex flex-col gap-1.5 overflow-auto pr-1 flex-1">
    {writeups?.slice(0, 8).map((w, idx) => (
      <a
        href={`/writeups/${w.id}`}
        class="flex items-start justify-between gap-2 py-1.5 border-b border-border/60 last:border-0 hover:border-primary/30 transition-colors group"
      >
        <div class="min-w-0 flex items-start gap-2">
          <span class="text-[10px] font-mono text-muted-foreground/60 tabular-nums mt-0.5">{String(idx + 1).padStart(2, "0")}</span>
          <span class="text-xs text-foreground/75 font-mono group-hover:text-primary/80 transition-colors leading-relaxed max-h-[2.5rem] overflow-hidden">
            {w.data.title}
          </span>
        </div>
        {w.data.pubDate && (
          <time
            class="text-[10px] text-muted-foreground shrink-0 tabular-nums"
            datetime={w.data.pubDate.toISOString()}
          >
            {formatDate(w.data.pubDate)}
          </time>
        )}
      </a>
    ))}
  </div>
</Card>

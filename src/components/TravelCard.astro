---
import Card from "./Card/index.astro";
---

<Card colSpan="md:col-span-1" rowSpan="md:row-span-2" title="visited" href="/travel">
  <div class="flex items-center justify-center flex-1 overflow-hidden">
    <div class="globe-dot" aria-hidden="true"></div>
  </div>
</Card>

<style>
  .globe-dot {
    width: 92px;
    height: 92px;
    border-radius: 9999px;
    border: 1px solid rgba(250, 204, 21, 0.25);
    background:
      radial-gradient(circle at 30% 30%, rgba(250, 204, 21, 0.85), rgba(26, 58, 92, 0.95) 45%, rgba(11, 22, 35, 1) 100%);
    box-shadow:
      inset -12px -14px 24px rgba(0, 0, 0, 0.35),
      inset 8px 8px 16px rgba(255, 255, 255, 0.08),
      0 0 0 1px rgba(255, 255, 255, 0.05),
      0 10px 30px rgba(26, 58, 92, 0.4);
    animation: globe-breathe 4.5s ease-in-out infinite;
  }

  @keyframes globe-breathe {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.04); }
  }
</style>

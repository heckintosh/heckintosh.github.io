---
import Card from "./Card/index.astro";
---

<Card colSpan="md:col-span-1" rowSpan="md:row-span-2" title="visited" href="/travel">
  <div class="flex items-center justify-center flex-1 overflow-hidden">
    <div class="globe-mini" aria-hidden="true">
      <div class="globe-mini__core">
        <span class="globe-mini__land globe-mini__land--1"></span>
        <span class="globe-mini__land globe-mini__land--2"></span>
        <span class="globe-mini__land globe-mini__land--3"></span>
        <span class="globe-mini__marker globe-mini__marker--vn"></span>
        <span class="globe-mini__marker globe-mini__marker--au"></span>
        <span class="globe-mini__marker globe-mini__marker--tw"></span>
      </div>
      <span class="globe-mini__ring globe-mini__ring--outer"></span>
      <span class="globe-mini__ring globe-mini__ring--inner"></span>
    </div>
  </div>
</Card>

<style>
  .globe-mini {
    position: relative;
    width: 106px;
    height: 106px;
    display: grid;
    place-items: center;
    filter: drop-shadow(0 14px 24px rgba(13, 30, 48, 0.38));
  }

  .globe-mini__core {
    width: 92px;
    height: 92px;
    border-radius: 9999px;
    border: 1px solid rgba(250, 204, 21, 0.25);
    background:
      radial-gradient(circle at 28% 26%, rgba(247, 205, 66, 0.82), rgba(44, 96, 145, 0.9) 45%, rgba(14, 29, 47, 1) 100%);
    box-shadow:
      inset -18px -20px 24px rgba(0, 0, 0, 0.35),
      inset 8px 10px 14px rgba(255, 255, 255, 0.09),
      inset 0 0 0 1px rgba(255, 255, 255, 0.07);
    position: relative;
    overflow: hidden;
  }

  .globe-mini__land {
    position: absolute;
    border-radius: 9999px;
    background: rgba(95, 173, 122, 0.78);
    filter: blur(0.2px);
  }

  .globe-mini__land--1 {
    width: 34px;
    height: 18px;
    top: 26px;
    left: 18px;
    transform: rotate(-12deg);
  }

  .globe-mini__land--2 {
    width: 24px;
    height: 13px;
    top: 44px;
    left: 50px;
    transform: rotate(10deg);
  }

  .globe-mini__land--3 {
    width: 14px;
    height: 9px;
    top: 58px;
    left: 62px;
    transform: rotate(-22deg);
  }

  .globe-mini__ring {
    position: absolute;
    border-radius: 9999px;
    pointer-events: none;
  }

  .globe-mini__ring--outer {
    inset: 5px;
    border: 1px dashed rgba(255, 255, 255, 0.2);
    transform: rotate(18deg);
  }

  .globe-mini__ring--inner {
    inset: 16px;
    border: 1px solid rgba(255, 255, 255, 0.14);
  }

  .globe-mini__marker {
    position: absolute;
    width: 5px;
    height: 5px;
    border-radius: 9999px;
    background: rgba(250, 204, 21, 0.95);
    box-shadow: 0 0 0 5px rgba(250, 204, 21, 0.12), 0 0 10px rgba(250, 204, 21, 0.55);
  }

  .globe-mini__marker--vn { top: 38px; left: 61px; }
  .globe-mini__marker--au { top: 65px; left: 72px; }
  .globe-mini__marker--tw { top: 34px; left: 70px; }

  :global(html.dark) .globe-mini {
    filter: drop-shadow(0 14px 28px rgba(4, 10, 18, 0.6));
  }

  :global(html.dark) .globe-mini__core {
    border-color: rgba(250, 204, 21, 0.35);
    background:
      radial-gradient(circle at 28% 26%, rgba(244, 209, 95, 0.9), rgba(39, 88, 133, 0.92) 45%, rgba(8, 18, 29, 1) 100%);
  }

  :global(html.dark) .globe-mini__ring--outer {
    border-color: rgba(255, 255, 255, 0.28);
  }

  :global(html.dark) .globe-mini__ring--inner {
    border-color: rgba(255, 255, 255, 0.2);
  }

  :global(html.dark) .globe-mini__land {
    background: rgba(119, 193, 144, 0.72);
  }
</style>

---
import Card from "./Card/index.astro";
---

<Card colSpan="md:col-span-1" rowSpan="md:row-span-2" title="visited" href="/travel">
  <div class="flex items-center justify-center flex-1 overflow-hidden">
    <div class="globe-mini" aria-hidden="true">
      <div class="globe-mini__core"></div>
      <span class="globe-mini__marker globe-mini__marker--vn"></span>
      <span class="globe-mini__marker globe-mini__marker--au"></span>
      <span class="globe-mini__marker globe-mini__marker--tw"></span>
      <span class="globe-mini__ring"></span>
    </div>
  </div>
</Card>

<style>
  .globe-mini {
    position: relative;
    width: 106px;
    height: 106px;
    display: grid;
    place-items: center;
    filter: drop-shadow(0 14px 24px rgba(13, 30, 48, 0.38));
  }

  .globe-mini__core {
    width: 92px;
    height: 92px;
    border-radius: 9999px;
    border: 1px solid rgba(250, 204, 21, 0.25);
    background:
      radial-gradient(circle at 28% 26%, rgba(247, 205, 66, 0.82), rgba(44, 96, 145, 0.9) 45%, rgba(14, 29, 47, 1) 100%);
    box-shadow:
      inset -18px -20px 24px rgba(0, 0, 0, 0.35),
      inset 8px 10px 14px rgba(255, 255, 255, 0.09),
      inset 0 0 0 1px rgba(255, 255, 255, 0.07);
    position: relative;
    overflow: hidden;
    animation: globe-spin 15s linear infinite;
  }

  .globe-mini__core::before,
  .globe-mini__core::after {
    content: "";
    position: absolute;
    inset: -10%;
    border-radius: 9999px;
    pointer-events: none;
  }

  .globe-mini__core::before {
    background:
      repeating-radial-gradient(circle at 55% 55%, transparent 0 8px, rgba(255, 255, 255, 0.06) 8px 9px);
    opacity: 0.45;
  }

  .globe-mini__core::after {
    background:
      linear-gradient(90deg, transparent 0 30%, rgba(255, 255, 255, 0.1) 44%, transparent 60%),
      linear-gradient(180deg, transparent 0 44%, rgba(255, 255, 255, 0.08) 50%, transparent 56%);
    mix-blend-mode: screen;
    opacity: 0.45;
  }

  .globe-mini__ring {
    position: absolute;
    inset: 5px;
    border-radius: 9999px;
    border: 1px dashed rgba(255, 255, 255, 0.18);
    animation: globe-orbit 12s linear infinite;
  }

  .globe-mini__marker {
    position: absolute;
    width: 5px;
    height: 5px;
    border-radius: 9999px;
    background: rgba(250, 204, 21, 0.95);
    box-shadow: 0 0 0 5px rgba(250, 204, 21, 0.12), 0 0 10px rgba(250, 204, 21, 0.6);
  }

  .globe-mini__marker--vn { top: 38px; left: 61px; }
  .globe-mini__marker--au { top: 65px; left: 72px; }
  .globe-mini__marker--tw { top: 34px; left: 70px; }

  @keyframes globe-spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  @keyframes globe-orbit {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(-360deg); }
  }
</style>

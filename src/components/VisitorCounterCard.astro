---
import Card from "./Card/index.astro";
---

<Card colSpan="lg:col-span-1" rowSpan="md:row-span-1" title="Visitors">
  <div class="flex flex-col items-center justify-center h-[calc(100%-28px)]">
    <div class="text-2xl font-mono tabular-nums" id="visitorCount">—</div>
    <div class="text-sm text-gray-500 mt-2" id="visitorLabel">Total Views</div>
  </div>
</Card>

<script>
  const el = document.getElementById("visitorCount") as HTMLElement;
  const label = document.getElementById("visitorLabel") as HTMLElement;

  function animateTo(target: number) {
    const start = performance.now();
    const duration = 900;
    function tick(now: number) {
      const t = Math.min((now - start) / duration, 1);
      // cubic ease-out
      const eased = 1 - Math.pow(1 - t, 3);
      el.textContent = Math.round(target * eased).toLocaleString();
      if (t < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  async function loadGlobalCount(): Promise<number | null> {
    try {
      const res = await fetch(
        "https://api.countapi.xyz/hit/heckintosh.github.io/visits",
        { mode: "cors" }
      );
      if (!res.ok) return null;
      const data = await res.json() as { value?: number };
      return typeof data.value === "number" ? data.value : null;
    } catch {
      return null;
    }
  }

  (async () => {
    const global = await loadGlobalCount();
    if (global !== null) {
      animateTo(global);
    } else {
      // Fallback: per-device localStorage count
      const n = parseInt(localStorage.getItem("visitorCount") ?? "0") + 1;
      localStorage.setItem("visitorCount", String(n));
      animateTo(n);
      label.textContent = "Your visits";
    }
  })();
</script>

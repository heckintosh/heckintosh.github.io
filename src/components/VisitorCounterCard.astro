---
import Card from "./Card/index.astro";
---

<Card colSpan="lg:col-span-1" rowSpan="md:row-span-2" title="visitors">
  <div class="flex flex-col items-center justify-center flex-1 gap-1">
    <div class="text-4xl font-mono font-light tabular-nums text-foreground" id="visitorCount">—</div>
    <div class="text-xs text-muted-foreground font-mono" id="visitorLabel">total views</div>
  </div>
</Card>

<script>
  const el    = document.getElementById("visitorCount") as HTMLElement;
  const label = document.getElementById("visitorLabel") as HTMLElement;

  function animateTo(target: number) {
    const t0 = performance.now();
    const dur = 900;
    function tick(now: number) {
      const p = Math.min((now - t0) / dur, 1);
      const e = 1 - Math.pow(1 - p, 3);
      el.textContent = Math.round(target * e).toLocaleString();
      if (p < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  async function loadCount(): Promise<number | null> {
    try {
      const res = await fetch("https://api.countapi.xyz/hit/heckintosh.github.io/visits", { mode: "cors" });
      if (!res.ok) return null;
      const d = await res.json() as { value?: number };
      return typeof d.value === "number" ? d.value : null;
    } catch { return null; }
  }

  (async () => {
    const global = await loadCount();
    if (global !== null) {
      animateTo(global);
    } else {
      const n = parseInt(localStorage.getItem("visitorCount") ?? "0") + 1;
      localStorage.setItem("visitorCount", String(n));
      animateTo(n);
      label.textContent = "your visits";
    }
  })();
</script>

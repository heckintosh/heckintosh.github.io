---
interface Props {
  title?: string;
  body?: string;
  colSpan?: string;
  rowSpan?: string;
  href?: string;
  colorText?: string;
  style?: string;
  class?: string;
}

const { title, body, colSpan, rowSpan, href, colorText, style, class: extraClass } = Astro.props;
---

<div
  class={`card card-glow h-full relative flex flex-col overflow-hidden rounded-lg border border-border bg-accent p-5 w-full
    ${colSpan ?? ''}
    ${rowSpan ?? ''}
    ${extraClass ?? ''}`}
  style={style}
>
  {href ? (
    <a href={href} class={`group flex flex-col h-full gap-3 ${colorText ?? ''}`}>
      <div class="flex items-start justify-between gap-2">
        {title && <h2 class="text-sm font-semibold tracking-widest uppercase text-primary/80 m-0">{title}</h2>}
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="opacity-30 shrink-0 group-hover:opacity-80 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-all mt-0.5">
          <path d="M7 17L17 7"/><path d="M7 7h10v10"/>
        </svg>
      </div>
      {body && <p class="m-0 text-sm text-muted-foreground">{body}</p>}
      <slot />
    </a>
  ) : (
    <div class="flex flex-col h-full gap-3">
      {title && <h2 class="text-sm font-semibold tracking-widest uppercase text-primary/80 m-0">{title}</h2>}
      {body && <p class="m-0 text-sm text-muted-foreground">{body}</p>}
      <slot />
    </div>
  )}
</div>

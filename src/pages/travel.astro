---
import OrbitalGlobe from "@/components/OrbitalGlobe.astro";
import BasicLayout from "@/layouts/BasicLayout.astro";

const visited = ["vietnam", "australia", "taiwan"];
---

<BasicLayout
  title="Anh - Visited Countries"
  description="Places I've been to: Vietnam, Australia, Taiwan"
  page="travel"
>
  <main class="travel-shell">
    <div class="travel-backdrop" aria-hidden="true">
      <div class="travel-glow travel-glow--gold"></div>
      <div class="travel-glow travel-glow--blue"></div>
      <div class="travel-grid"></div>
      <div class="travel-stars travel-stars--near"></div>
      <div class="travel-stars travel-stars--far"></div>
    </div>

    <div class="travel-actions">
      <a href="/" class="travel-back">← back</a>
    </div>

    <section class="travel-hero">
      <div class="travel-copy">
        <p class="travel-label">visited // atlas</p>
        <h1 class="travel-title">countries touched</h1>
        <p class="travel-summary">
          A cleaner travel view with the globe doing the talking instead of sitting inside another box.
        </p>
      </div>

      <div class="travel-globe-wrap">
        <OrbitalGlobe />
      </div>

      <div class="travel-meta">
        <p class="travel-meta-label">route</p>
        <p class="travel-list">{visited.join(" · ")}</p>
      </div>
    </section>
  </main>
</BasicLayout>

<style>
  .travel-shell {
    min-height: 100vh;
    position: relative;
    overflow: hidden;
    isolation: isolate;
    background:
      radial-gradient(1100px 640px at 12% 0%, rgba(248, 214, 103, 0.16), transparent 60%),
      radial-gradient(1100px 640px at 88% 8%, rgba(91, 151, 227, 0.22), transparent 58%),
      linear-gradient(180deg, #f4f8fd 0%, #e6eef8 52%, #edf3fb 100%);
  }

  .travel-backdrop,
  .travel-hero {
    position: relative;
    min-height: 100vh;
  }

  .travel-backdrop {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .travel-glow {
    position: absolute;
    border-radius: 999px;
    filter: blur(50px);
    opacity: 0.9;
  }

  .travel-glow--gold {
    width: 28rem;
    height: 28rem;
    top: -8rem;
    left: -6rem;
    background: radial-gradient(circle, rgba(255, 214, 99, 0.28), transparent 68%);
  }

  .travel-glow--blue {
    width: 34rem;
    height: 34rem;
    right: -10rem;
    bottom: -12rem;
    background: radial-gradient(circle, rgba(96, 159, 255, 0.26), transparent 68%);
  }

  .travel-grid {
    position: absolute;
    inset: 0;
    opacity: 0.25;
    background-image:
      linear-gradient(rgba(77, 120, 170, 0.12) 1px, transparent 1px),
      linear-gradient(90deg, rgba(77, 120, 170, 0.12) 1px, transparent 1px);
    background-size: 4.75rem 4.75rem;
    mask-image: radial-gradient(circle at center, black 20%, transparent 84%);
  }

  .travel-stars {
    position: absolute;
    inset: 0;
    opacity: 0.8;
    background-repeat: no-repeat;
  }

  .travel-stars--near {
    background-image:
      radial-gradient(circle at 12% 18%, rgba(255,255,255,0.95) 0 1.2px, transparent 1.4px),
      radial-gradient(circle at 22% 66%, rgba(255,255,255,0.82) 0 1.1px, transparent 1.35px),
      radial-gradient(circle at 37% 24%, rgba(255,246,210,0.92) 0 1.4px, transparent 1.7px),
      radial-gradient(circle at 48% 82%, rgba(255,255,255,0.75) 0 1.15px, transparent 1.4px),
      radial-gradient(circle at 64% 14%, rgba(199,228,255,0.92) 0 1.3px, transparent 1.6px),
      radial-gradient(circle at 78% 58%, rgba(255,255,255,0.82) 0 1.1px, transparent 1.35px),
      radial-gradient(circle at 88% 28%, rgba(255,246,210,0.95) 0 1.45px, transparent 1.75px);
  }

  .travel-stars--far {
    opacity: 0.52;
    background-image:
      radial-gradient(circle at 8% 44%, rgba(255,255,255,0.8) 0 0.8px, transparent 1px),
      radial-gradient(circle at 17% 82%, rgba(199,228,255,0.7) 0 0.85px, transparent 1.05px),
      radial-gradient(circle at 29% 10%, rgba(255,255,255,0.72) 0 0.75px, transparent 0.95px),
      radial-gradient(circle at 41% 58%, rgba(255,255,255,0.65) 0 0.85px, transparent 1.05px),
      radial-gradient(circle at 54% 30%, rgba(255,246,210,0.7) 0 0.8px, transparent 1px),
      radial-gradient(circle at 68% 76%, rgba(255,255,255,0.68) 0 0.85px, transparent 1.05px),
      radial-gradient(circle at 82% 12%, rgba(199,228,255,0.68) 0 0.85px, transparent 1.05px),
      radial-gradient(circle at 93% 64%, rgba(255,255,255,0.74) 0 0.8px, transparent 1px);
  }

  .travel-actions {
    position: fixed;
    top: 1.25rem;
    left: 1.25rem;
    right: 1.25rem;
    z-index: 20;
    pointer-events: none;
  }

  .travel-back {
    display: inline-flex;
    align-items: center;
    pointer-events: auto;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #5d6a81;
    border: 1px solid rgba(196, 209, 225, 0.9);
    padding: 0.58rem 0.92rem;
    border-radius: 999px;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.68);
    backdrop-filter: blur(12px);
    transition: color 180ms ease, border-color 180ms ease, transform 180ms ease, background 180ms ease;
  }

  .travel-back:hover {
    color: #b17f05;
    border-color: rgba(177, 127, 5, 0.4);
    transform: translateY(-1px);
    background: rgba(255, 255, 255, 0.82);
  }

  .travel-hero {
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    align-items: center;
    justify-items: center;
    padding: 5.5rem 1.25rem 2rem;
  }

  .travel-copy,
  .travel-meta {
    position: absolute;
    z-index: 2;
    width: min(22rem, calc(100vw - 2.5rem));
  }

  .travel-copy {
    top: clamp(5.75rem, 8vw, 7rem);
    left: clamp(1.25rem, 4vw, 3rem);
  }

  .travel-meta {
    right: clamp(1.25rem, 4vw, 3rem);
    bottom: clamp(1.5rem, 4vw, 2.75rem);
    text-align: right;
  }

  .travel-label,
  .travel-meta-label {
    margin: 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #b07f05;
  }

  .travel-title {
    margin: 0.65rem 0 0;
    max-width: 9ch;
    font-size: clamp(2.7rem, 8vw, 5.8rem);
    line-height: 0.88;
    letter-spacing: -0.05em;
    font-weight: 800;
    color: #203148;
    text-wrap: balance;
  }

  .travel-summary {
    margin: 1rem 0 0;
    max-width: 28ch;
    font-size: 0.98rem;
    line-height: 1.6;
    color: rgba(45, 63, 88, 0.8);
  }

  .travel-globe-wrap {
    width: min(100%, 78rem);
    display: grid;
    place-items: center;
    padding-inline: clamp(0rem, 1vw, 1rem);
  }

  .travel-list {
    margin: 0.4rem 0 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #657895;
  }

  :global(html.dark) .travel-shell {
    background:
      radial-gradient(1100px 640px at 12% 0%, rgba(248, 214, 103, 0.1), transparent 60%),
      radial-gradient(1100px 640px at 88% 8%, rgba(91, 151, 227, 0.16), transparent 58%),
      linear-gradient(180deg, #07111d 0%, #091724 52%, #0b1622 100%);
  }

  :global(html.dark) .travel-grid {
    opacity: 0.16;
    background-image:
      linear-gradient(rgba(117, 167, 226, 0.13) 1px, transparent 1px),
      linear-gradient(90deg, rgba(117, 167, 226, 0.13) 1px, transparent 1px);
  }

  :global(html.dark) .travel-back {
    color: #9cb0cd;
    border-color: rgba(77, 100, 133, 0.86);
    background: rgba(8, 16, 29, 0.64);
  }

  :global(html.dark) .travel-back:hover {
    color: #f4d66f;
    border-color: rgba(244, 214, 111, 0.4);
    background: rgba(9, 18, 32, 0.8);
  }

  :global(html.dark) .travel-label,
  :global(html.dark) .travel-meta-label {
    color: #f0ca53;
  }

  :global(html.dark) .travel-title {
    color: #e0ecfa;
  }

  :global(html.dark) .travel-summary {
    color: rgba(194, 211, 232, 0.76);
  }

  :global(html.dark) .travel-list {
    color: #8fa1bc;
  }

  @media (max-width: 900px) {
    .travel-hero {
      padding-top: 5.75rem;
      padding-bottom: 1.5rem;
      align-content: center;
      gap: 1.2rem;
    }

    .travel-copy,
    .travel-meta {
      position: relative;
      width: min(100%, 34rem);
      inset: auto;
      text-align: left;
    }

    .travel-copy {
      justify-self: start;
    }

    .travel-title {
      max-width: none;
      font-size: clamp(2.4rem, 12vw, 4.2rem);
    }

    .travel-summary {
      max-width: 34ch;
    }

    .travel-globe-wrap {
      width: 100%;
      order: 3;
    }

    .travel-meta {
      order: 4;
    }

    .travel-list {
      letter-spacing: 0.12em;
    }
  }
</style>

---
import OrbitalGlobe from "@/components/OrbitalGlobe.astro";
import BasicLayout from "@/layouts/BasicLayout.astro";
---

<BasicLayout
  title="Anh - Visited Countries"
  description="Places I've been to: Vietnam, Australia, Taiwan"
  page="travel"
>
  <div class="travel-shell" id="travel-shell">
    <div class="travel-noise" aria-hidden="true"></div>
    <div class="travel-orb travel-orb--a" aria-hidden="true"></div>
    <div class="travel-orb travel-orb--b" aria-hidden="true"></div>

    <div class="travel-actions">
      <a href="/" class="travel-back">← back</a>
    </div>

    <div class="travel-panel" id="travel-panel">
      <p class="travel-label">visited // atlas</p>
      <h1 class="travel-title">countries touched</h1>

      <div class="travel-globe-wrap" id="travel-globe-wrap">
        <OrbitalGlobe />
      </div>

      <p class="travel-list">vietnam · australia · taiwan</p>
    </div>
  </div>
</BasicLayout>

<style>
  .travel-shell {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem 1rem;
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(900px 480px at 16% -10%, rgba(248, 209, 82, 0.35), transparent 60%),
      radial-gradient(1000px 560px at 88% -20%, rgba(77, 125, 181, 0.36), transparent 62%),
      #eef1f7;
  }

  .travel-noise {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.28;
    background-image:
      radial-gradient(rgba(0,0,0,0.12) 0.45px, transparent 0.45px);
    background-size: 4px 4px;
    mix-blend-mode: soft-light;
  }

  .travel-orb {
    position: absolute;
    border-radius: 9999px;
    filter: blur(24px);
    pointer-events: none;
  }

  .travel-orb--a {
    width: 320px;
    height: 320px;
    top: -70px;
    right: -70px;
    background: radial-gradient(circle, rgba(248, 209, 82, 0.5), transparent 70%);
  }

  .travel-orb--b {
    width: 280px;
    height: 280px;
    bottom: -60px;
    left: -50px;
    background: radial-gradient(circle, rgba(77, 125, 181, 0.52), transparent 70%);
  }

  .travel-actions {
    position: fixed;
    top: 1.2rem;
    left: 1.2rem;
    right: 1.2rem;
    z-index: 20;
    display: flex;
    justify-content: space-between;
    pointer-events: none;
  }

  .travel-back {
    pointer-events: auto;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: #5c6a84;
    border: 1px solid #d4dbe8;
    padding: 0.48rem 0.86rem;
    border-radius: 0.5rem;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.76);
    backdrop-filter: blur(10px);
    transition: border-color 180ms ease, color 180ms ease, transform 180ms ease;
  }

  .travel-back:hover {
    color: #b17f05;
    border-color: rgba(177, 127, 5, 0.45);
    transform: translateY(-1px);
  }

  .travel-panel {
    position: relative;
    z-index: 5;
    width: min(980px, 100%);
    border: 1px solid rgba(208, 216, 229, 0.76);
    border-radius: 1.35rem;
    padding: 1.2rem 1.2rem 1.05rem;
    background:
      linear-gradient(140deg, rgba(255, 255, 255, 0.84), rgba(248, 251, 255, 0.66)),
      radial-gradient(circle at 18% 8%, rgba(248, 209, 82, 0.18), transparent 56%),
      radial-gradient(circle at 82% 18%, rgba(77, 125, 181, 0.18), transparent 52%);
    box-shadow: 0 28px 56px rgba(18, 39, 63, 0.14), inset 0 1px 0 rgba(255, 255, 255, 0.5);
  }

  .travel-label {
    margin: 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #b07f05;
  }

  .travel-title {
    margin: 0.45rem 0 0.9rem;
    font-size: clamp(1.25rem, 2.8vw, 1.9rem);
    line-height: 1.1;
    color: #223046;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .travel-globe-wrap {
    position: relative;
    border: 1px solid rgba(208, 216, 229, 0.74);
    border-radius: 1.1rem;
    padding: 0.85rem;
    background:
      radial-gradient(circle at 40% -10%, rgba(77, 125, 181, 0.12), transparent 52%),
      radial-gradient(circle at 70% 120%, rgba(248, 209, 82, 0.12), transparent 50%),
      linear-gradient(180deg, rgba(251, 253, 255, 0.84), rgba(243, 248, 254, 0.74));
    overflow: hidden;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.52);
  }

  .travel-globe-wrap :global(svg) {
    width: min(100%, 640px);
    height: auto;
    display: block;
    margin: 0 auto;
  }

  .travel-list {
    margin: 0.95rem 0 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: #70829f;
    letter-spacing: 0.04em;
  }

  :global(html.dark) .travel-shell {
    background:
      radial-gradient(900px 480px at 16% -10%, rgba(248, 209, 82, 0.16), transparent 60%),
      radial-gradient(1000px 560px at 88% -20%, rgba(77, 125, 181, 0.22), transparent 62%),
      #090f18;
  }

  :global(html.dark) .travel-noise {
    opacity: 0.17;
  }

  :global(html.dark) .travel-back {
    color: #8b9cb8;
    border-color: rgba(72, 95, 127, 0.78);
    background: rgba(10, 18, 30, 0.74);
  }

  :global(html.dark) .travel-back:hover {
    color: #f5d56a;
    border-color: rgba(245, 213, 106, 0.45);
  }

  :global(html.dark) .travel-panel {
    border-color: rgba(65, 86, 114, 0.72);
    background:
      linear-gradient(145deg, rgba(10, 19, 32, 0.88), rgba(8, 15, 26, 0.76)),
      radial-gradient(circle at 16% 12%, rgba(248, 209, 82, 0.1), transparent 58%),
      radial-gradient(circle at 82% 18%, rgba(89, 135, 190, 0.12), transparent 56%);
    box-shadow: 0 30px 56px rgba(2, 7, 14, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  :global(html.dark) .travel-label {
    color: #f0ca53;
  }

  :global(html.dark) .travel-title {
    color: #dde8f7;
  }

  :global(html.dark) .travel-globe-wrap {
    border-color: rgba(65, 86, 114, 0.72);
    background:
      radial-gradient(circle at 40% -10%, rgba(77, 125, 181, 0.16), transparent 52%),
      radial-gradient(circle at 70% 120%, rgba(248, 209, 82, 0.1), transparent 50%),
      linear-gradient(180deg, rgba(7, 14, 24, 0.88), rgba(8, 16, 29, 0.78));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  :global(html.dark) .travel-list {
    color: #8fa1bc;
  }
</style>

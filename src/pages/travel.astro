---
import Globe from "@/components/Globe";
import BasicLayout from "@/layouts/BasicLayout.astro";
---

<BasicLayout
  title="Anh - Visited Countries"
  description="Places I've been to: Vietnam, Australia, Taiwan"
  page="travel"
>
  <div class="relative flex flex-col items-center justify-center min-h-screen bg-background">
    <a
      href="/"
      class="absolute top-5 left-5 flex items-center gap-1.5 px-3 py-1.5 text-xs border border-border rounded font-mono text-muted-foreground hover:text-foreground hover:border-foreground/30 transition-colors z-10"
    >
      ← back
    </a>

    <div class="text-center mb-4">
      <h1 class="text-sm font-mono font-semibold tracking-widest uppercase text-primary/80 m-0">visited</h1>
      <p class="text-xs text-muted-foreground font-mono mt-1">vietnam · australia · taiwan</p>
    </div>

    <Globe client:load />
  </div>
</BasicLayout>

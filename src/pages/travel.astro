---
import GlobeFull from "@/components/GlobeFull";
import BasicLayout from "@/layouts/BasicLayout.astro";
---

<BasicLayout
  title="Anh - Visited Countries"
  description="Places I've been to: Vietnam, Australia, Taiwan"
  page="travel"
>
  <div class="travel-shell">
    <a
      href="/"
      class="travel-back"
    >
      ← back
    </a>

    <div class="travel-panel">
      <p class="travel-label">visited</p>
      <h1 class="travel-title">countries touched</h1>

      <div class="travel-globe-wrap">
        <GlobeFull client:load />
      </div>

      <p class="travel-list">vietnam · australia · taiwan</p>
    </div>
  </div>
</BasicLayout>

<style>
  .travel-shell {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    background:
      radial-gradient(900px 480px at 16% -10%, rgba(248, 209, 82, 0.28), transparent 60%),
      radial-gradient(1000px 560px at 88% -20%, rgba(77, 125, 181, 0.28), transparent 62%),
      #eef1f7;
  }

  .travel-back {
    position: fixed;
    top: 1.25rem;
    left: 1.25rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: #5f6c83;
    text-decoration: none;
    border: 1px solid #d8dee8;
    padding: 0.45rem 0.8rem;
    border-radius: 0.5rem;
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(8px);
    z-index: 10;
    transition: border-color 180ms ease, color 180ms ease, transform 180ms ease;
  }

  .travel-back:hover {
    color: #b07f05;
    border-color: rgba(176, 127, 5, 0.45);
    transform: translateY(-1px);
  }

  .travel-panel {
    width: min(980px, 100%);
    border: 1px solid rgba(208, 216, 229, 0.95);
    border-radius: 1rem;
    padding: 1.25rem 1.25rem 1rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(251, 253, 255, 0.74));
    box-shadow: 0 20px 42px rgba(18, 39, 63, 0.12);
  }

  .travel-label {
    margin: 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #b07f05;
  }

  .travel-title {
    margin: 0.45rem 0 0.9rem;
    font-size: clamp(1.25rem, 2.4vw, 1.65rem);
    line-height: 1.1;
    color: #223046;
    font-weight: 700;
    text-transform: lowercase;
  }

  .travel-globe-wrap {
    border: 1px solid rgba(208, 216, 229, 0.85);
    border-radius: 0.9rem;
    padding: 0.5rem;
    background:
      radial-gradient(circle at 50% 0%, rgba(77, 125, 181, 0.14), transparent 48%),
      radial-gradient(circle at 50% 100%, rgba(248, 209, 82, 0.13), transparent 46%),
      rgba(250, 252, 255, 0.86);
  }

  .travel-globe-wrap :global(canvas) {
    width: 100%;
    display: block;
  }

  .travel-list {
    margin: 0.95rem 0 0;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: #70829f;
    letter-spacing: 0.04em;
  }
</style>

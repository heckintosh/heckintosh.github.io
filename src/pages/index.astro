---
import Layout from "@/layouts/Layout.astro";
import IntroCard from "@/components/IntroCard.astro";
import Writeups from "@/components/Writeups.astro";
import TerminalCard from "@/components/TerminalCard.astro";
import TravelCard from "@/components/TravelCard.astro";
import VisitorCounterCard from "@/components/VisitorCounterCard.astro";
import { getCollection } from "astro:content";
import { formatDate } from "@/lib/helpers";
import Card from "@/components/Card/index.astro";

const posts = (await getCollection("blog"))?.sort(
  (a, b) => (b.data.pubDate ?? new Date()).getTime() - (a.data.pubDate ?? new Date()).getTime()
);

const cveShowcase = [
  {
    id: "CVE-20XX-XXXX",
    title: "Stored XSS in enterprise dashboard",
    severity: "high",
    href: "/writeups",
  },
  {
    id: "CVE-20XX-YYYY",
    title: "Auth bypass via misconfigured token check",
    severity: "critical",
    href: "/writeups",
  },
];

const bountyShowcase = [
  {
    target: "Program A",
    impact: "Account takeover on admin panel",
    href: "/writeups",
  },
  {
    target: "Program B",
    impact: "IDOR leaking sensitive customer data",
    href: "/writeups",
  },
];
---

<script>
  const cards = document.querySelectorAll(".card");
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  cards.forEach((card, index) => {
    if (prefersReducedMotion) {
      card.style.opacity = "1";
      return;
    }

    const delay = index * 45;
    card.animate(
      [
        { opacity: 0, transform: "translateY(24px)" },
        { opacity: 1, transform: "translateY(0)" },
      ],
      {
        duration: 360,
        delay,
        easing: "cubic-bezier(0.22, 1, 0.36, 1)",
        fill: "both",
      }
    );
  });
</script>

<Layout title="Heckintosh's Blog" description="Security researcher & CTF player">
  <!--
    Grid: 5 cols × 8 rows on lg+, fluid 2-col on md, single col on mobile.
    All cards use explicit lg:col-start / lg:row-start for zero-gap placement.

    Layout (lg):
      Cols 1-3  rows 1-4 → IntroCard
      Col  4    rows 1-4 → Writeups
      Col  5    rows 1-4 → CVE
      Cols 1-2  rows 5-8 → Blog
      Col  3    rows 5-8 → BugBounty
      Col  4    rows 5-6 → VisitorCounter
      Col  4    rows 7-8 → TravelCard
      Col  5    rows 5-8 → TerminalCard
  -->
  <main class="
    mx-auto px-4 py-4 grid gap-3 w-full
    max-w-7xl
    md:grid-cols-2
    lg:grid-cols-5
    lg:grid-rows-8
    lg:h-screen
    lg:max-h-[900px]
    lg:gap-3
  ">

    <!-- IntroCard: cols 1-3, rows 1-4 -->
    <div class="md:col-span-2 lg:col-span-3 lg:row-span-4 lg:col-start-1 lg:row-start-1">
      <IntroCard />
    </div>

    <!-- Writeups: col 4, rows 1-4 -->
    <div class="md:col-span-1 lg:col-span-1 lg:row-span-4 lg:col-start-4 lg:row-start-1">
      <Writeups />
    </div>

    <!-- CVE Showcase: col 5, rows 1-4 -->
    <div class="md:col-span-1 lg:col-span-1 lg:row-span-4 lg:col-start-5 lg:row-start-1">
      <Card title="cve" titleHref="/writeups">
        <div class="flex flex-col gap-2 overflow-auto pr-1 flex-1">
          {cveShowcase.map((item) => (
            <a
              href={item.href}
              class="border border-border/60 rounded-lg p-2.5 hover:border-primary/40 transition-colors group"
            >
              <p class="m-0 text-[10px] text-primary/80 font-mono tracking-wide">{item.id}</p>
              <p class="m-0 mt-1 text-xs text-foreground/80 leading-relaxed group-hover:text-primary/80 transition-colors">
                {item.title}
              </p>
              <p class="m-0 mt-1 text-[10px] text-muted-foreground font-mono uppercase">{item.severity}</p>
            </a>
          ))}
        </div>
      </Card>
    </div>

    <!-- Blog: cols 1-2, rows 5-8 -->
    <div class="md:col-span-2 lg:col-span-2 lg:row-span-4 lg:col-start-1 lg:row-start-5">
      <Card title="blog" titleHref="/blog">
        <div class="flex flex-col gap-0.5 overflow-auto pr-1 flex-1">
          {posts?.slice(0, 6).map(post => (
            <a
              href={`/blog/${post.id}`}
              class="flex items-baseline justify-between gap-2 py-1.5 border-b border-border/60 last:border-0 hover:border-primary/30 transition-colors group"
            >
              <span class="text-xs text-foreground/75 font-mono group-hover:text-primary/80 transition-colors max-h-[2.5rem] overflow-hidden">
                {post.data.title}
              </span>
              {post.data.pubDate && (
                <time
                  class="text-[10px] text-muted-foreground shrink-0 tabular-nums"
                  datetime={post.data.pubDate.toISOString()}
                >
                  {formatDate(post.data.pubDate)}
                </time>
              )}
            </a>
          ))}
        </div>
      </Card>
    </div>

    <!-- Bug Bounty Showcase: col 3, rows 5-8 -->
    <div class="md:col-span-1 lg:col-span-1 lg:row-span-4 lg:col-start-3 lg:row-start-5">
      <Card title="bug bounty" titleHref="/writeups">
        <div class="flex flex-col gap-2 overflow-auto pr-1 flex-1">
          {bountyShowcase.map((item, idx) => (
            <a
              href={item.href}
              class="border border-border/60 rounded-lg p-2.5 hover:border-primary/40 transition-colors group"
            >
              <p class="m-0 text-[10px] text-muted-foreground font-mono tracking-wide">report #{String(idx + 1).padStart(2, "0")}</p>
              <p class="m-0 mt-1 text-xs text-foreground/80 leading-relaxed group-hover:text-primary/80 transition-colors">
                {item.impact}
              </p>
              <p class="m-0 mt-1 text-[10px] text-primary/80 font-mono uppercase">{item.target}</p>
            </a>
          ))}
        </div>
      </Card>
    </div>

    <!-- VisitorCounter: col 4, rows 5-6 -->
    <div class="md:col-span-1 lg:col-span-1 lg:row-span-2 lg:col-start-4 lg:row-start-5">
      <VisitorCounterCard />
    </div>

    <!-- TravelCard: col 4, rows 7-8 -->
    <div class="md:col-span-1 lg:col-span-1 lg:row-span-2 lg:col-start-4 lg:row-start-7">
      <TravelCard />
    </div>

    <!-- TerminalCard: col 5, rows 5-8 -->
    <div class="md:col-span-1 lg:col-span-1 lg:row-span-4 lg:col-start-5 lg:row-start-5">
      <TerminalCard />
    </div>

  </main>
</Layout>
